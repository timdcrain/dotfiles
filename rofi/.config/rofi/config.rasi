configuration {
	lines: 5;
	font: "Roboto 35";
	separator-style: "none";
	hide-scrollbar: true;
	color-normal: "#393939, #ffffff, #393939, #268bd2, #ffffff";
	color-urgent: "#393939, #f3843d, #393939, #268bd2, #ffc39c";
	color-active: "#393939, #268bd2, #393939, #268bd2, #205171";
	color-window: "#393939, #393939, #268bd2";
}
