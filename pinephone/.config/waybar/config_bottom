{
  "layer": "top",
  "position": "bottom",

  "modules-left": [
    "custom/kill"
  ],

  "modules-center": [
    "custom/home"
  ],

  "modules-right": [
    "custom/keyboard"
  ],

  "custom/kill": {
    "on-click": "~/.local/bin/kill",
    "format": ""
  },

  "custom/home": {
    "on-click": "~/.local/bin/home",
    "format": ""
  },

  "custom/launcher": {
    "on-click": "~/.local/bin/launcher",
    "format": "",
    "format-icons": ["", ""]
  },

  "custom/keyboard": {
    "on-click": "~/.local/bin/toggle_keyboard",
    "format": ""
  }
}
