{
  "layer": "top",
  "position": "top",

  "modules-left": [
    "sway/workspaces",
    "tray"
  ],

  "modules-center": [
  ],

  "modules-right": [
    "pulseaudio",
    "network",
    "battery",
    "clock"
  ],

  "battery": {
    "interval": 1,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format-charging": " {capacity}%",
    "format": "{icon} {capacity}%",
    "format-icons": ["", "", "", "", ""],
    "tooltip": false
  },

  "clock": {
    "interval": 1,
    "locale": "C",
    "timezone": "America/Los_Angeles",
    "format": " {:%Y.%m.%d %H:%M}",
    "tooltip": false
  },

  "network": {
    "interval": 5,
    "format-wifi": " {essid}",
    "format-ethernet": "",
    "format-disconnected": "",
    "tooltip": false
  },

  "pulseaudio": {
    "format": " {volume}%",
    "format-muted": "{volume}%"
  },

  "sway/workspaces": {
    "disable-scroll": true,
    "format": "{name}"
  },

  "tray": {
    "icon-size": 22
  }
}
