{
  "layer": "top",
  "position": "top",

  "modules-left": [
    "sway/workspaces"
  ],

  "modules-center": [
  ],

  "modules-right": [
    "tray",
    "pulseaudio",
    "network",
    "battery",
    "clock"
  ],

  "battery": {
    "interval": 1,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format-charging": "",
    "format": "{icon}",
    "format-icons": ["", "", "", "", ""],
    "tooltip": false
  },

  "clock": {
    "interval": 1,
    "locale": "C",
    "timezone": "America/Los_Angeles",
    "format": "{:%Y.%m.%d  %H:%M}",
    "tooltip": false
  },

  "network": {
    "interval": 1,
    "interface": "wlp58s0",
    "format": "{icon}",
    "format-icons": {
        "wifi": [""],
        "ethernet": [""],
        "disconnected": [""]
    },
    "tooltip-format-wifi": "{essid} {signalStrength}%",
    "tooltip": true,
    "on-click": "~/.local/bin/wifi-menu"
  },

  "pulseaudio": {
    "format": " ",
    "format-muted": "",
    "on-click": "pavucontrol",
    "tooltip": false
  },

  "sway/workspaces": {
    "disable-scroll": true,
    "format": "{name}"
  }
}
