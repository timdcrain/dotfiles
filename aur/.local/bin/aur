#!/bin/sh

aur_pkg_cache=${XDG_CACHE_HOME:-$HOME/.cache}/aur/pkg

if [ ! -d ${aur_pkg_cache} ]; then
    mkdir -p ${aur_pkg_cache}
fi

# Operations
op_files=0
op_query=0
op_remove=0
op_sync=0
op_deptest=0
op_upgrade=0

# Options
search=0
refresh=0
upgrade=0

while getopts "FQRSTUsyu" option; do
    case "${option}" in
        F) op_files=1 ;;
        Q) op_query=1 ;;
        R) op_remove=1 ;;
        S) op_sync=1 ;;
        T) op_deptest=1 ;;
        U) op_upgrade=1 ;;
        s) search=1 ;;
        y) refresh=1 ;;
        u) upgrade=1 ;;
    esac
done

shift $((OPTIND - 1))
packages="$@"

if [ $((op_files + op_query + op_remove + op_sync + op_deptest + op_upgrade)) -gt 1 ]; then
    echo "error: only one operation may be used at a time" >&2
    exit 1
fi

if [ "${op_files}" -eq 1 ]; then
    echo "error: not implemented" >&2
    exit 1
fi

if [ "${op_query}" -eq 1 ]; then
    if [ -z "${packages}" ]; then
        for package in ${aur_pkg_cache}/*; do
            packages="${packages} ${package##*/}"
        done
    fi

    ret=0
    for package in ${packages}; do
        if [ ! -d ${aur_pkg_cache}/${package} ]; then
            echo "error: package '${package}' was not found" >&2
            ret=1
        else
            . ${aur_pkg_cache}/${package}/PKGBUILD
            echo "${package} ${pkgver}-${pkgrel}"
        fi
    done

    exit ${ret}
fi

if [ "${op_remove}" -eq 1 ]; then
    echo "error: not implemented" >&2
    exit 1
fi

if [ "${op_sync}" -eq 1 ]; then
    if [ "${search}" -eq 1 ]; then
        if [ "${upgrade}" -eq 1 ]; then
            echo "error: invalid option: '--search' and '--sysupgrade' may not be used together" >&2
            exit 1
        fi

        echo "Search currently not supported."
    fi

    if [ "${refresh}" -eq 1 ]; then
        echo ":: Synchronizing package databases..."
        for package in ${aur_pkg_cache}/*; do
            cd ${package}
            synced="$(git remote update 2>&1)"
            if [ -z "$(git rev-list HEAD..@{u})" ]; then
                echo " ${package##*/} is up to date"
            else
                echo " ${package##*/}"
                echo " ${synced}"
            fi
        done
    fi

    if [ "${upgrade}" -eq 1 ]; then
        echo ":: Starting full system upgrade..."
        changes=0
        for package in ${aur_pkg_cache}/*; do
            cd ${package}
            # Only install if there are changes in upstream.
            if [ ! -z "$(git rev-list HEAD..@{u})" ]; then
                changes=1
                git pull --ff-only
                makepkg -srci
                git clean -fdx
            fi
        done

        if [ "${changes}" -eq 0 ]; then
            echo " there is nothing to do"
        fi
    fi

    if [ "${search}" -eq 0 ] && [ "${refresh}" -eq 0 ] && [ "${upgrade}" -eq 0 ] && [ -z "${packages}" ]; then
        echo "error: no targets specified (use -h for help)" >&2
        exit 1
    fi

    for package in ${packages}; do
        if [ ! -d ${aur_pkg_cache}/${package} ]; then
            git clone "https://aur.archlinux.org/${package}.git" ${aur_pkg_cache}/${package}
        fi

        cd ${aur_pkg_cache}/${package}
        makepkg -srci
        git clean -fdx
    done
fi

if [ "${op_deptest}" -eq 1 ]; then
    echo "error: not implemented" >&2
    exit 1
fi

if [ "${op_upgrade}" -eq 1 ]; then
    echo "error: not implemented" >&2
    exit 1
fi
